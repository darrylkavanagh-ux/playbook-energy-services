# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/foxlite_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foxlite_db
DB_USER=foxlite_user
DB_PASSWORD=your_secure_password

# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# OAuth Configuration (from shared/const.ts)
VITE_OAUTH_PORTAL_URL=https://oauth.example.com
VITE_APP_ID=your_app_id

# Analytics
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id

# OCR Service (Google Cloud Vision API)
GOOGLE_CLOUD_VISION_API_KEY=your_google_vision_api_key
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud-keyfile.json

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/jpg

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@foxlite.ie

# Email Bill Processing (IMAP for receiving bills)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=bills@foxlite.ie
EMAIL_PASSWORD=your_email_password
EMAIL_TLS=true
EMAIL_REJECT_UNAUTHORIZED=true
EMAIL_CHECK_INTERVAL=5

# External APIs
# Irish Energy Suppliers (for rate scraping)
ENABLE_RATE_SCRAPING=true
SCRAPE_INTERVAL_HOURS=24

# CRU (Commission for Regulation of Utilities)
CRU_API_ENDPOINT=https://www.cru.ie/api
CRU_API_KEY=your_cru_api_key_if_available

# HIQA (Health Information and Quality Authority)
HIQA_REGISTRY_URL=https://www.hiqa.ie/areas-we-work/regulation

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Commission Rates
DEFAULT_COMMISSION_RATE=0.20
MIN_COMMISSION_RATE=0.15
MAX_COMMISSION_RATE=0.25

# Audit Configuration
DEFAULT_AUDIT_PERIOD_YEARS=6
MAX_BILLS_PER_AUDIT=1000

# Testing
TEST_MODE=false
MOCK_OCR=false
MOCK_SUPPLIERS=false

# ============================================================================
# FORENSIC INVESTIGATION PLATFORM v2 — NEW VARIABLES
# ============================================================================

# TRM BLOCKINT (Blockchain Intelligence — server-side ONLY, never expose to client)
TRM_API_KEY=your_trm_api_key_here
TRM_BASE_URL=https://api.trmlabs.com/public/v2
TRM_MAX_RETRIES=5
TRM_INITIAL_BACKOFF_MS=1000
TRM_MAX_BACKOFF_MS=60000
TRM_CONCURRENCY_LIMIT=3
TRM_CACHE_TTL_MS=300000
TRM_DAILY_QUOTA_LIMIT=10000
TRM_ENVIRONMENT=production
# Separate test key — NEVER use production key in test/staging
TRM_TEST_API_KEY=your_trm_test_api_key_here

# Evidence Vault Security
# CRITICAL: Set a strong random secret — minimum 64 chars
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
EVIDENCE_VAULT_SECRET=generate_a_strong_64_char_secret_here
EVIDENCE_STORAGE_PATH=./uploads/evidence
VAULT_LOCATION=Orb AI Forensic Vault — Dublin, Ireland

# RBAC / JWT
# CRITICAL: Set a strong random secret — minimum 64 chars
JWT_SECRET=generate_a_strong_64_char_jwt_secret_here
SESSION_TTL_MS=28800000

# OCR Integrations (optional — platform works without these)
# Tesseract OCR (local — no key required, install tesseract binary)
TESSERACT_BINARY_PATH=/usr/bin/tesseract
# AWS Textract (cloud OCR — higher accuracy)
AWS_TEXTRACT_REGION=eu-west-1
AWS_TEXTRACT_ACCESS_KEY_ID=your_aws_access_key
AWS_TEXTRACT_SECRET_ACCESS_KEY=your_aws_secret_key
# Google Vision API (cloud OCR + object detection)
GOOGLE_VISION_KEY=your_google_vision_api_key

# Forensic Platform URLs
FORENSIC_PLATFORM_BASE_URL=https://your-railway-app.railway.app
FORENSIC_PLATFORM_CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Reporting
REPORT_STORAGE_PATH=./reports
REPORT_ORGANISATION_NAME=Orb AI Forensic Platform
REPORT_DEFAULT_AUTHOR=Lead Analyst

# Security hardening
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000
