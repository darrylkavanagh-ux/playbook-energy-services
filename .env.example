# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/foxlite_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foxlite_db
DB_USER=foxlite_user
DB_PASSWORD=your_secure_password

# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d

# OAuth Configuration (from shared/const.ts)
VITE_OAUTH_PORTAL_URL=https://oauth.example.com
VITE_APP_ID=your_app_id

# Analytics
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your_website_id

# OCR Service (Google Cloud Vision API)
GOOGLE_CLOUD_VISION_API_KEY=your_google_vision_api_key
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud-keyfile.json

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/jpg

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@foxlite.ie

# Email Bill Processing (IMAP for receiving bills)
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=bills@foxlite.ie
EMAIL_PASSWORD=your_email_password
EMAIL_TLS=true
EMAIL_REJECT_UNAUTHORIZED=true
EMAIL_CHECK_INTERVAL=5

# External APIs
# Irish Energy Suppliers (for rate scraping)
ENABLE_RATE_SCRAPING=true
SCRAPE_INTERVAL_HOURS=24

# CRU (Commission for Regulation of Utilities)
CRU_API_ENDPOINT=https://www.cru.ie/api
CRU_API_KEY=your_cru_api_key_if_available

# HIQA (Health Information and Quality Authority)
HIQA_REGISTRY_URL=https://www.hiqa.ie/areas-we-work/regulation

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Commission Rates
DEFAULT_COMMISSION_RATE=0.20
MIN_COMMISSION_RATE=0.15
MAX_COMMISSION_RATE=0.25

# Audit Configuration
DEFAULT_AUDIT_PERIOD_YEARS=6
MAX_BILLS_PER_AUDIT=1000

# Testing
TEST_MODE=false
MOCK_OCR=false
MOCK_SUPPLIERS=false

# ============================================================================
# FORENSIC INVESTIGATION PLATFORM v2 — NEW VARIABLES
# ============================================================================

# TRM BLOCKINT (Blockchain Intelligence — server-side ONLY, never expose to client)
TRM_API_KEY=your_trm_api_key_here
TRM_BASE_URL=https://api.trmlabs.com/public/v2
TRM_MAX_RETRIES=5
TRM_INITIAL_BACKOFF_MS=1000
TRM_MAX_BACKOFF_MS=60000
TRM_CONCURRENCY_LIMIT=3
TRM_CACHE_TTL_MS=300000
TRM_DAILY_QUOTA_LIMIT=10000
TRM_ENVIRONMENT=production
# Separate test key — NEVER use production key in test/staging
TRM_TEST_API_KEY=your_trm_test_api_key_here

# Evidence Vault Security
# CRITICAL: Set a strong random secret — minimum 64 chars
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
EVIDENCE_VAULT_SECRET=generate_a_strong_64_char_secret_here
EVIDENCE_STORAGE_PATH=./uploads/evidence
VAULT_LOCATION=Orb AI Forensic Vault — Dublin, Ireland

# RBAC / JWT
# CRITICAL: Set a strong random secret — minimum 64 chars
JWT_SECRET=generate_a_strong_64_char_jwt_secret_here
SESSION_TTL_MS=28800000

# OCR Integrations (optional — platform works without these)
# Tesseract OCR (local — no key required, install tesseract binary)
TESSERACT_BINARY_PATH=/usr/bin/tesseract
# AWS Textract (cloud OCR — higher accuracy)
AWS_TEXTRACT_REGION=eu-west-1
AWS_TEXTRACT_ACCESS_KEY_ID=your_aws_access_key
AWS_TEXTRACT_SECRET_ACCESS_KEY=your_aws_secret_key
# Google Vision API (cloud OCR + object detection)
GOOGLE_VISION_KEY=your_google_vision_api_key

# Forensic Platform URLs
FORENSIC_PLATFORM_BASE_URL=https://your-railway-app.railway.app
FORENSIC_PLATFORM_CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# Reporting
REPORT_STORAGE_PATH=./reports
REPORT_ORGANISATION_NAME=Orb AI Forensic Platform
REPORT_DEFAULT_AUTHOR=Lead Analyst

# Security hardening
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# ============================================================================
# MULTI-ASSET TRADING ENGINE — NEW API KEYS (all free tiers available)
# ============================================================================

# Alpha Vantage — Forex intraday + Stock daily OHLCV
# Free tier: 500 requests/day | Sign up: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub — Real-time stock quotes, company news, forex candles
# Free tier: 60 req/min, real-time data | Sign up: https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# NewsAPI — 80,000+ news sources, keyword search
# Free tier: 100 req/day (developer) | Sign up: https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Financial Modeling Prep — Stock quotes + fundamentals
# Free tier: 250 req/day | Sign up: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# CryptoCompare — OHLCV crypto history
# Free tier: 100,000 req/month | Sign up: https://min-api.cryptocompare.com
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key_here

# ── Data fallback chain ─────────────────────────────────────────────────────
# FOREX:  Alpha Vantage → Frankfurter ECB (free, no key) → ExchangeRate-API
# CRYPTO: CoinGecko (free, no key) → Binance (free, no key) → CryptoCompare
# STOCKS: Alpha Vantage → Finnhub → Financial Modeling Prep
# The system runs without any keys using public no-auth endpoints.
# API keys unlock higher rate limits and intraday candle history.

# ── HITL Trading Portal Auth ────────────────────────────────────────────────
# Set to 'true' to require HITL approval before signals are flagged live-ready
REQUIRE_HITL_APPROVAL=true
# Trader credential type required for HITL sign-off
# Options: FCA_CISI_LEVEL_3 | FINRA_SERIES_65 | CISI_CHARTERED | MiFID_QUALIFIED
REQUIRED_TRADER_CREDENTIAL=FCA_CISI_LEVEL_3

# ── Phantom Account ─────────────────────────────────────────────────────────
PHANTOM_STARTING_BALANCE=10000

# ============================================================================
# SUPABASE — PLAYBOOK TRADING DATABASE (REQUIRED for production)
# ============================================================================
# Get these from: https://app.supabase.com → Project Settings → API
#
# SUPABASE_URL: Your project URL (e.g. https://abcdefgh.supabase.co)
# SUPABASE_ANON_KEY: Safe to use in browser (RLS enforced)
# SUPABASE_SERVICE_ROLE_KEY: Server-side only — NEVER expose to client
#   ⚠️  CRITICAL: Keep SERVICE_ROLE_KEY secret — it bypasses all RLS policies
#
# After adding these to Railway env vars, run:
#   POST /api/trading/admin/migrate  — creates all Playbook Trading tables
#
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Supabase Database Direct Connection ────────────────────────────────────
# Use the pooler connection string for Railway (Transaction mode, port 6543)
# Get from: Supabase → Project Settings → Database → Connection string
SUPABASE_DB_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
# OR use Transaction pooler for serverless:
SUPABASE_POOLER_URL=postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# ============================================================================
# REDIS — CACHING + RATE LIMITING (P1 — optional but recommended)
# ============================================================================
# Free options: Upstash (https://upstash.com — free 10K req/day)
#               Redis Cloud (https://redis.com/try-free — 30MB free)
# Railway: Add Redis service from marketplace → copy REDIS_URL
#
# When set, Redis is used for:
#   - Signal cache (60s TTL per symbol)
#   - Rate limiting (API key quotas per tier)
#   - Session storage (HITL trader sessions)
#   - WebSocket pub/sub for multi-instance scaling
#
REDIS_URL=redis://default:password@host:6379
# Or Upstash TLS:
# REDIS_URL=rediss://default:token@endpoint.upstash.io:6379

# ============================================================================
# WEBSOCKET SERVER — REAL-TIME STREAMING (P1)
# ============================================================================
# WebSocket is served on the same port as the HTTP server (/ws path)
# No separate port needed — ws:// upgrade handled by Node http.Server
# Client connects via: ws://your-domain.com/ws
#
WS_MAX_CLIENTS=1000
WS_HEARTBEAT_INTERVAL_MS=30000
WS_RECONNECT_ENABLED=true

# ============================================================================
# WEBHOOKS — OUTBOUND EVENT DELIVERY (P1)
# ============================================================================
# Register webhooks via POST /api/trading/webhooks
# Supported types: SLACK, TEAMS, DISCORD, CUSTOM
#
# Default webhook for admin alerts (optional):
ADMIN_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
ADMIN_TEAMS_WEBHOOK=https://your-org.webhook.office.com/webhookb2/YOUR/TEAMS/WEBHOOK

# ============================================================================
# PLAYBOOK TRADING SaaS — SUBSCRIPTION TIERS
# ============================================================================
# Monthly pricing: Starter $49 / Professional $199 / Enterprise $799 / Institutional $2,999
# Stripe integration (coming Phase 2):
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly
STRIPE_INSTITUTIONAL_PRICE_ID=price_institutional_monthly

# ============================================================================
# SIGNAL CALIBRATION — ISOTONIC REGRESSION
# ============================================================================
# Auto-retrain after N new resolved outcomes (default: 10)
CALIBRATION_RETRAIN_INTERVAL=10
# Minimum resolved outcomes before model is considered valid
CALIBRATION_MIN_SAMPLES=30
# Expected Calibration Error threshold — alert if ECE exceeds this
CALIBRATION_ECE_ALERT_THRESHOLD=0.10

# ============================================================================
# CENTRAL BANK NLP — P1
# ============================================================================
# Fed RSS feed (free): https://www.federalreserve.gov/feeds/press_all.xml
# ECB Press releases: https://www.ecb.europa.eu/press/pressconf/html
# No API key required for RSS-based ingestion
CB_NLP_AUTO_FETCH=false     # Set true to enable auto-fetch (P1)
CB_NLP_FETCH_INTERVAL_HOURS=6
FED_RSS_URL=https://www.federalreserve.gov/feeds/press_all.xml
ECB_RSS_URL=https://www.ecb.europa.eu/rss/press.rss
BOE_RSS_URL=https://www.bankofengland.co.uk/rss/publications

# ============================================================================
# SMART MONEY FLOW — P1
# ============================================================================
# CFTC COT data (free, weekly): https://www.cftc.gov/dea/newcot/f_futopt.txt
# Unusual Whales (options flow): https://unusualwhales.com/api (paid)
# FINRA ATS dark pool: https://finra-markets.morningstar.com/MarketData/EquityMarkets/dollarDominanceReport.jsp
CFTC_COT_AUTO_FETCH=false   # Set true to enable weekly auto-fetch
UNUSUAL_WHALES_API_KEY=your_unusual_whales_api_key

# ============================================================================
# PHASE 2 — FRACTAL PATTERN MATCHER / GEX MAP / ALT DATA (P2)
# ============================================================================
# Google Trends API (free via pytrends):
GOOGLE_TRENDS_ENABLED=false
# Satellite NDVI data (Copernicus / NASA Earthdata):
SATELLITE_DATA_ENABLED=false
COPERNICUS_API_KEY=your_copernicus_api_key
# AIS vessel tracking (marine traffic):
AIS_API_KEY=your_ais_api_key
# FIX Protocol order management (P2):
FIX_ENABLED=false
FIX_HOST=your-fix-server.com
FIX_PORT=9876
FIX_SENDER_COMP_ID=PLAYBOOKTRADING
FIX_TARGET_COMP_ID=BROKER
