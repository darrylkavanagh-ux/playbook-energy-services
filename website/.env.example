// Environment variables for the Foxlite Excalibur Trading Dashboard
// Add these to your deployment environment (Vercel, Netlify, etc.)

// Twelve Data API Configuration
NEXT_PUBLIC_TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

// Alternative APIs (if needed)
NEXT_PUBLIC_ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

// Trading Dashboard Configuration
NEXT_PUBLIC_TRADING_REFRESH_INTERVAL=60000
NEXT_PUBLIC_TRADING_ENABLED=true

// Instructions:
// 1. Sign up for free API key at https://twelvedata.com/
// 2. Add the API key to your deployment environment variables
// 3. The dashboard will automatically use the API key for live data
// 4. Free tier allows 8 calls per minute, perfect for 60-second refresh rate